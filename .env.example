# ============================================
# 大学导航员 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# ---- 数据库 ----
# PostgreSQL 连接字符串
# 本地开发示例：postgresql://用户名:密码@localhost:5432/数据库名?schema=public
# Vercel 部署时使用 Vercel Postgres 提供的连接字符串
DATABASE_URL="postgresql://postgres:password@localhost:5432/university_navigator?schema=public"

# ---- AI 模型配置 ----
# OpenAI 兼容的 API Key
# 支持国内大模型（DeepSeek、通义千问等），填入对应平台的 API Key
OPENAI_API_KEY="your-api-key-here"

# OpenAI 兼容的 API 基础 URL
# DeepSeek: https://api.deepseek.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI 官方: https://api.openai.com/v1
OPENAI_BASE_URL="https://api.deepseek.com/v1"

# AI 模型名称
# DeepSeek: deepseek-chat
# 通义千问: qwen-plus
# OpenAI: gpt-4o-mini
OPENAI_MODEL="deepseek-chat"

# ---- Auth.js v5 认证配置 ----
# GitHub OAuth App 凭证
# 获取方式：GitHub -> Settings -> Developer settings -> OAuth Apps -> New OAuth App
# Authorization callback URL 填写：http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID="your-github-oauth-app-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-secret"

# Auth.js 加密密钥，用于签名 JWT 会话
# 生成命令：openssl rand -base64 32
AUTH_SECRET="your-random-secret-key"

# ---- Upstash Redis（分布式限流） ----
# 用于多实例部署（如 Vercel）时的分布式速率限制
# 获取方式：https://upstash.com -> Create Database -> 复制 REST API 凭证
#
# 本地开发：可不配置，将自动降级为内存限流（仅支持单实例）
# ⚠️ 生产环境（NODE_ENV=production）：必填！
#    src/lib/rate-limit.ts 的 assertProductionConfig() 会在首次限流调用时
#    硬阻断并抛错（"生产环境必须配置 UPSTASH_REDIS_REST_URL 和 ..._TOKEN"）。
#    两个变量必须同时提供，且 URL 需为合法 URL（env.ts 用 z.string().url() 校验）。
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
